  },
  "type": "module",
  "bin": {
    "engram": "dist/cli.js",
    "engramx": "dist/cli.js",
    "engram-serve": "dist/serve.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "structural-code-graph",
