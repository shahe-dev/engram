  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "graphology": "^0.26.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
